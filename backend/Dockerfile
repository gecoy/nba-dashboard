# 1. ไปยืมเครื่องเปล่าๆ ที่ติดตั้ง Go 1.21 มาให้แล้ว
FROM golang:1.25-alpine

# 2. เข้าไปทำงานในโฟลเดอร์ /app ภายในตู้
WORKDIR /app

# 3. ก๊อปปี้ไฟล์รายชื่อแพ็กเกจ แล้วสั่งโหลดให้ครบ
COPY go.mod go.sum ./
RUN go mod download

# 4. ก๊อปปี้โค้ด Go ทั้งหมดของเราเข้าไป
COPY . .

# 5. สั่ง Build โค้ดให้เป็นไฟล์โปรแกรมที่รันได้ชื่อว่า "main"
RUN go build -o main .

# 6. บอกว่าตู้นี้จะเปิดประตูหมายเลข 8080 ให้คนคุยด้วย
EXPOSE 8080

# 7. คำสั่งตอนเปิดตู้ คือให้รันไฟล์ "main"
CMD ["./main"]